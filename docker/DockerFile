FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

# Install system dependencies
RUN apt-get update && apt-get install -y \
    software-properties-common \
    curl \
    wget \
    && add-apt-repository ppa:deadsnakes/ppa -y \
    && apt-get update \
    && apt-get install -y \
    python3.14 \
    python3.14-dev \
    python3.14-venv \
    apache2 \
    apache2-dev \
    postgresql \
    postgresql-contrib \
    libpq-dev \
    sqlite3 \
    libsqlite3-dev \
    build-essential \
    net-tools \
    dos2unix \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Set Python 3.14 as default
RUN update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.14 1
RUN update-alternatives --install /usr/bin/python python /usr/bin/python3.14 1

# Install pip for Python 3.14
RUN curl -sS https://bootstrap.pypa.io/get-pip.py | python3.14

# Install mod_wsgi
RUN pip3 install mod-wsgi

# Create necessary directories
RUN mkdir -p /var/run/apache2 /var/lock/apache2 /var/log/apache2 /var/www/html
RUN chown -R www-data:www-data /var/run/apache2 /var/lock/apache2 /var/log/apache2 /var/www/html
RUN chmod -R 755 /var/run/apache2 /var/lock/apache2 /var/log/apache2

# Create envvars file
RUN cat > /etc/apache2/envvars << 'EOF'
export APACHE_RUN_USER=www-data
export APACHE_RUN_GROUP=www-data
export APACHE_PID_FILE=/var/run/apache2/apache2.pid
export APACHE_RUN_DIR=/var/run/apache2
export APACHE_LOCK_DIR=/var/lock/apache2
export APACHE_LOG_DIR=/var/log/apache2
export LANG=C
EOF

# Create ports.conf
RUN echo "Listen 80" > /etc/apache2/ports.conf && \
    echo "Listen 443" >> /etc/apache2/ports.conf

# Create apache2.conf
RUN cat > /etc/apache2/apache2.conf << 'EOF'
ServerName localhost
User www-data
Group www-data
Include ports.conf
LoadModule mpm_prefork_module /usr/lib/apache2/modules/mod_mpm_prefork.so
IncludeOptional mods-enabled/*.load
IncludeOptional mods-enabled/*.conf
IncludeOptional sites-enabled/*.conf
ErrorLog ${APACHE_LOG_DIR}/error.log
LogLevel warn
EOF

# Configure wsgi
RUN WSGI_PATH=$(find /usr/local/lib/python3.14 -name "mod_wsgi*.so" 2>/dev/null | head -1) && \
    echo "LoadModule wsgi_module $WSGI_PATH" > /etc/apache2/mods-available/wsgi.load && \
    ln -sf /etc/apache2/mods-available/wsgi.load /etc/apache2/mods-enabled/wsgi.load

# Enable modules
RUN a2enmod ssl headers rewrite

# Enable mpm_prefork
RUN rm -f /etc/apache2/mods-enabled/mpm_*.load /etc/apache2/mods-enabled/mpm_*.conf 2>/dev/null || true && \
    ln -sf /etc/apache2/mods-available/mpm_prefork.load /etc/apache2/mods-enabled/mpm_prefork.load && \
    ln -sf /etc/apache2/mods-available/mpm_prefork.conf /etc/apache2/mods-enabled/mpm_prefork.conf

WORKDIR /app

COPY requirements.txt /app/
RUN pip3 install --no-cache-dir -r requirements.txt

COPY . /app/

# Copy your configuration files
COPY docker/apache/django.conf /etc/apache2/sites-available/django.conf
COPY docker/apache/ssl /etc/apache2/ssl/

# Create static/media directories
RUN mkdir -p /app/staticfiles /app/mediafiles && \
    chown -R www-data:www-data /app && \
    chmod -R 755 /app

# Enable site
RUN a2ensite django.conf && \
    a2dissite 000-default.conf 2>/dev/null || true

# Create apache2.conf with WSGIPythonPath globally
RUN cat > /etc/apache2/apache2.conf << 'EOF'
ServerName localhost
User www-data
Group www-data

# Add Python path globally (outside VirtualHost)
WSGIPythonPath /app

Include ports.conf
LoadModule mpm_prefork_module /usr/lib/apache2/modules/mod_mpm_prefork.so
IncludeOptional mods-enabled/*.load
IncludeOptional mods-enabled/*.conf
IncludeOptional sites-enabled/*.conf
ErrorLog ${APACHE_LOG_DIR}/error.log
LogLevel warn
EOF

    
RUN dos2unix /etc/apache2/sites-available/django.conf

EXPOSE 80 443

CMD ["/bin/bash", "-c", "source /etc/apache2/envvars && apache2ctl -D FOREGROUND"]